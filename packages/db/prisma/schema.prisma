// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users            Users[]
  inventoryLedgers InventoryLedger[]
  productions      Production[]
  expenses         Expense[]
  posTransactions  PosTransaction[]

  @@map("store")
}

model Users {
  id           BigInt   @id @default(autoincrement())
  storeId      BigInt?
  email        String   @unique @db.VarChar(255)
  password     String   @db.VarChar(255)
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  refreshToken String?
  slug         String?  @db.VarChar(255)

  store           Store?           @relation(fields: [storeId], references: [id])
  employees       Employee?
  customer        Customer?
  posTransactions PosTransaction[]

  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  KASIR
  GUDANG
  CUSTOMER
}

model Categories {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String   @db.VarChar(100)
  status      Boolean  @default(true)
  slug        String   @unique @db.VarChar(100)
  createdAt   DateTime @default(now())

  productMasters ProductMaster[]

  @@map("categories")
}

model ProductMaster {
  id          BigInt        @id @default(autoincrement())
  name        String        @db.VarChar(255)
  description String?
  categoryId  BigInt?
  slug        String        @unique @db.VarChar(255)
  useVariant  Boolean       @default(false)
  type        ProductType   @default(MADE_TO_ORDER)
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())

  variants      ProductVariant[]
  variantTypes  ProductVariantType[]
  categories    Categories?          @relation(fields: [categoryId], references: [id])
  productImages ProductImage[]

  @@map("product_master")
}

enum ProductStatus {
  ACTIVE
  NONACTIVE
  DRAFT
}

enum ProductType {
  MADE_TO_ORDER
  PRE_ORDER
  READY_STOCK
}

model ProductImage {
  id              BigInt @id @default(autoincrement())
  productMasterId BigInt
  image           String

  productMaster ProductMaster @relation(fields: [productMasterId], references: [id], onDelete: Cascade)

  @@map("product_image")
}

model ProductVariant {
  id              BigInt   @id @default(autoincrement())
  productMasterId BigInt
  sku             String   @unique @db.VarChar(100)
  price           Decimal  @db.Decimal(18, 2)
  cost            Decimal? @db.Decimal(18, 2)
  isActive        Boolean  @default(true)
  image           String?  @db.VarChar(255)
  createdAt       DateTime @default(now())

  productMaster        ProductMaster          @relation(fields: [productMasterId], references: [id], onDelete: Cascade)
  options              ProductVariantOption[]
  productVariantStocks ProductVariantStock?
  productions          Production[]
  orderItems           OrderItem[]
  posTransactionItems  PosTransactionItem[]

  @@index([productMasterId])
  @@map("product_variant")
}

model ProductVariantStock {
  id               BigInt   @id @default(autoincrement())
  productVariantId BigInt   @unique
  stock            Int
  reserved_stock   Int
  updated_at       DateTime @default(now())

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("product_variant_stock")
}

model ProductVariantType {
  id              BigInt @id @default(autoincrement())
  productMasterId BigInt
  name            String @db.VarChar(255)

  productMaster ProductMaster         @relation(fields: [productMasterId], references: [id], onDelete: Cascade)
  values        ProductVariantValue[]

  @@unique([productMasterId, name])
  @@index([productMasterId])
  @@map("product_variant_type")
}

model ProductVariantValue {
  id            BigInt @id @default(autoincrement())
  variantTypeId BigInt
  value         String @db.VarChar(100)

  variantType ProductVariantType     @relation(fields: [variantTypeId], references: [id], onDelete: Cascade)
  options     ProductVariantOption[]

  @@unique([variantTypeId, value])
  @@index([variantTypeId])
  @@map("product_variant_value")
}

model ProductVariantOption {
  id               BigInt @id @default(autoincrement())
  productVariantId BigInt
  variantValueId   BigInt

  productVariant ProductVariant      @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  variantValue   ProductVariantValue @relation(fields: [variantValueId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, variantValueId])
  @@index([productVariantId])
  @@index([variantValueId])
  @@map("product_variant_option")
}

model Customer {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(255)
  phone     String?  @db.VarChar(255)
  image     String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  userId         BigInt?          @unique
  users          Users?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders         Order[]
  beSpokeDetails BeSpokeDetails[]

  @@map("customer")
}

model Employee {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(100)
  address   String?  @db.VarChar(255)
  phone     String?  @db.VarChar(15)
  createdAt DateTime @default(now())
  image     String?  @db.VarChar(255)

  users  Users  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId BigInt @unique

  @@map("employee")
}

// ==================
// Inventory Ledger
// ==================

model InventoryLedger {
  id          BigInt            @id @default(autoincrement())
  storeId     BigInt
  itemType    InventoryItemType
  itemId      BigInt
  direction   LedgerDirection
  source      LedgerSource
  quantity    Int
  referenceId BigInt?
  createdAt   DateTime          @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId, itemType, itemId])
  @@map("inventory_ledger")
}

enum InventoryItemType {
  PRODUCT_VARIANT
}

enum LedgerDirection {
  IN
  OUT
}

enum LedgerSource {
  PRODUCTION
  POS
  ONLINE_ORDER
  ADJUSTMENT
}

// ==================
// PRODUKSI INTERNAL
// ==================

model Production {
  id                BigInt           @id @default(autoincrement())
  storeId           BigInt
  producedVariantId BigInt?
  quantityProduced  Int
  type              ProductionType   @default(RESTOCK)
  status            ProductionStatus
  notes             String?
  targetDate        DateTime
  createdAt         DateTime         @default(now())

  store          Store           @relation(fields: [storeId], references: [id])
  variant        ProductVariant? @relation(fields: [producedVariantId], references: [id])
  beSpokeDetails BeSpokeDetails?

  @@map("production")
}

enum ProductionType {
  RESTOCK
  MADE_TO_ORDER
  BE_SPOKE
  PRE_ORDER
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ==================
// EXPENSE
// ==================

model ExpenseCategory {
  id          BigInt    @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String?
  color       String    @db.VarChar(100)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  expenses    Expense[]

  @@map("expense_category")
}

model Expense {
  id          BigInt   @id @default(autoincrement())
  storeId     BigInt
  date        DateTime
  categoryId  BigInt
  description String?
  totalAmount Decimal
  createdAt   DateTime @default(now())

  expenseCategory ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)

  expenseItem ExpenseItem[]

  @@map("expense")
}

model ExpenseItem {
  id        BigInt  @id @default(autoincrement())
  expenseId BigInt
  itemName  String? @db.VarChar(100)
  quantity  Int
  unit      String  @db.VarChar(100)
  price     Decimal
  subtotal  Decimal

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@map("expense_item")
}

// ==================
// E-COMMERCE & Be Spoke
// ==================

model Order {
  id                BigInt      @id @default(autoincrement())
  branchId          BigInt
  customerId        BigInt?
  orderId           String      @unique @db.VarChar(100)
  paymentMethodId   BigInt
  paymentGatewayRef String?     @db.VarChar(255)
  status            OrderStatus
  totalAmount       Decimal
  createdAt         DateTime    @default(now())

  customer Customer?      @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  shipment Shipment?
  payment  PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@map("order")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

model OrderItem {
  id               BigInt  @id @default(autoincrement())
  orderId          BigInt
  productVariantId BigInt
  quantity         Int
  price            Decimal
  subtotal         Decimal

  order   Order          @relation(fields: [orderId], references: [id])
  variant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@map("order_item")
}

model BeSpokeDetails {
  id           BigInt   @id @default(autoincrement())
  productionId BigInt   @unique
  customerId   BigInt?
  title        String   @db.VarChar(100)
  description  String?
  quotedPrice  Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())

  production Production @relation(fields: [productionId], references: [id])
  customer   Customer?  @relation(fields: [customerId], references: [id])
  shipments  Shipment?

  @@map("be_spoke_details")
}

model Shipment {
  id               BigInt   @id @default(autoincrement())
  orderId          BigInt?  @unique
  beSpokeDetailsId BigInt?  @unique
  recipientName    String   @db.VarChar(255)
  phone            String   @db.VarChar(15)
  addressLine      String
  city             String   @db.VarChar(100)
  province         String   @db.VarChar(100)
  courier          String   @db.VarChar(100)
  shippingCost     Decimal
  createdAt        DateTime @default(now())

  order          Order?          @relation(fields: [orderId], references: [id])
  beSpokeDetails BeSpokeDetails? @relation(fields: [beSpokeDetailsId], references: [id])

  @@map("shipment")
}

// ==================
// PAYMENT & FINANCE
// ==================

model PaymentMethod {
  id              BigInt           @id @default(autoincrement())
  code            String           @unique @db.VarChar(100)
  name            String           @db.VarChar(100)
  channel         PaymentChannel
  isActive        Boolean          @default(true)
  orders          Order[]
  posTransactions PosTransaction[]

  @@map("payment_method")
}

enum PaymentChannel {
  CASH
  MIDTRANS
  BANK_TRANSFER
}

model CashTransaction {
  id          BigInt     @id @default(autoincrement())
  branchId    BigInt
  type        CashType
  amount      Decimal
  source      CashSource
  referenceId BigInt
  note        String?
  createdAt   DateTime   @default(now())

  @@map("cash_transaction")
}

enum CashType {
  IN
  OUT
}

enum CashSource {
  POS
  ORDER
  EXPENSE
  PRODUCTION
}

model QrisPaymentDetail {
  id            String         @id @default(cuid())
  transactionId BigInt         @unique
  transaction   PosTransaction @relation(fields: [transactionId], references: [id])
  midtransId    String? // order_id Midtrans untuk webhook lookup
  qrString      String?
  qrUrl         String?
  qrExpiresAt   DateTime?
}

model TransferPaymentDetail {
  id            BigInt         @id @default(autoincrement())
  transactionId BigInt         @unique
  transaction   PosTransaction @relation(fields: [transactionId], references: [id])
  bank          String         @db.VarChar(50)
  paymentProof  String?        @db.VarChar(500)
  confirmedAt   DateTime?

  @@map("transfer_payment_detail")
}

// ==================
// POS (OFFLINE SALES)
// ==================

model PosTransaction {
  id              BigInt    @id @default(autoincrement())
  storeId         BigInt
  cashierId       BigInt
  transId         String    @unique @db.VarChar(100)
  paymentMethodId BigInt?
  status          PosStatus
  totalAmount     Decimal
  createdAt       DateTime  @default(now())

  store         Store          @relation(fields: [storeId], references: [id])
  users         Users          @relation(fields: [cashierId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  items                 PosTransactionItem[]
  qrisPaymentDetails    QrisPaymentDetail?
  transferPaymentDetail TransferPaymentDetail?

  @@map("pos_transaction")
}

enum PosStatus {
  PENDING
  PARKED
  PAID
  CANCELLED
}

model PosTransactionItem {
  id               BigInt  @id @default(autoincrement())
  posTransactionId BigInt
  productVariantId BigInt
  quantity         Int
  price            Decimal
  subtotal         Decimal

  posTransaction PosTransaction @relation(fields: [posTransactionId], references: [id])
  variant        ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([posTransactionId, productVariantId])
  @@map("pos_transaction_item")
}
